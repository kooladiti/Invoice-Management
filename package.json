{
  "name": "invoice-management",
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "install-all": "npm install --prefix frontend && npm install --prefix backend",

    "build": "npm run build --prefix frontend",

    "start": "npm start --prefix backend",

    "dev": "concurrently \"npm start --prefix backend\" \"npm start --prefix frontend\""
  },
  "dependencies": {
    "bootstrap": "^5.3.8"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}